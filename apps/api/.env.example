# Server Configuration
PORT=3000
NODE_ENV=development
# For local webhook testing with ngrok, you can run API on 5000:
# PORT=5000

# Client URL (for CORS and OAuth redirects)
CLIENT_URL=http://localhost:5000
CLIENT_URLS=http://localhost:5000

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com -> Connect -> Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/nexusmcp?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# MCP Gateway / Jira integration
JIRA_GATEWAY_ENDPOINT=http://localhost:8001/invoke
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
# Auto status after issue creation via Jira create_issue
JIRA_NEW_ISSUE_DEFAULT_STATUS=In Progress
# If Slack event already references an existing Jira ticket, update it to this status instead of creating a new ticket
JIRA_EXISTING_ISSUE_STATUS=In Progress
# Auto status when GitHub bug branch/PR is merged to tracked branches
JIRA_MERGED_BRANCH_DONE_STATUS=Done
JIRA_MERGE_DONE_BRANCHES=main,master
# Set true only if GitHub webhook flow should create new Jira tickets when no issue key is detected.
# Default behavior (false) avoids duplicate/unnecessary Jira tickets on push/PR/branch events.
GITHUB_CREATE_JIRA_WHEN_NO_ISSUE_KEY=false

# Agentic Flow Python service
AGENTIC_SERVICE_URL=http://localhost:8010
AGENTIC_SERVICE_TIMEOUT_MS=30000

# Webhook security placeholders
WEBHOOK_SHARED_TOKEN=change-me-shared-webhook-token
GITHUB_WEBHOOK_SECRET=change-me-github-secret

# Webhook queue/idempotency settings
WEBHOOK_QUEUE_POLL_INTERVAL_MS=250
WEBHOOK_IDEMPOTENCY_TTL_MS=3600000

# Optional: owner whose saved missing-details memory should be auto-applied
# to webhook executions. Leave empty to use anonymous memory scope.
WEBHOOK_MISSING_DETAIL_OWNER_USER_ID=

# Webhook trigger mode
# true by default to keep the 3 predefined workflows always active for testing.
WEBHOOK_ALWAYS_ON_PREDEFINED_WORKFLOWS=true
# Set true only if you want planner-first mode.
WEBHOOK_USE_AGENTIC_PLANNER=false

# Slack workflow channel filter
# Only Slack message events from these channels trigger the Slack default workflow.
# Comma-separated values; supports channel names (with or without #) and channel IDs.
SLACK_WORKFLOW_ALLOWED_CHANNELS=#bug-reporting
