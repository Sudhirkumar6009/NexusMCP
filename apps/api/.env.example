# Server Configuration
PORT=3000
NODE_ENV=development

# Client URL (for CORS and OAuth redirects)
CLIENT_URL=http://localhost:5000
CLIENT_URLS=http://localhost:5000

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com -> Connect -> Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/nexusmcp?retryWrites=true&w=majority

# PostgreSQL Configuration (Audit logs + workflow runtime persistence)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/NexusMCP
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=NexusMCP
PGSSL=false
PG_MAX_CLIENTS=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
CREDENTIALS_ENCRYPTION_KEY=change-this-to-a-strong-random-value

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# MCP Gateway / Jira integration
JIRA_GATEWAY_ENDPOINT=http://localhost:8001/invoke
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Agentic Flow Python service
AGENTIC_SERVICE_URL=http://localhost:8010
AGENTIC_SERVICE_TIMEOUT_MS=30000
