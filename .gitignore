# Monorepo ignores
node_modules/

# Client artifacts
client/node_modules/
client/.next/
client/out/
client/build/
client/.vercel/
client/*.tsbuildinfo

# Server artifacts
server/node_modules/
server/dist/
server/*.tsbuildinfo

# Env files (keep examples)
.env
.env.*
!.env.example
client/.env
client/.env.*
!client/.env.example
server/.env
server/.env.*
!server/.env.example

# Logs and coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Root Next.js cache
.next/
